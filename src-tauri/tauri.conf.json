{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "envyou",
  "version": "1.0.0",
  "identifier": "com.envyou.app",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "envyou",
        "width": 360,
        "height": 520,
        "minWidth": 280,
        "minHeight": 320,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": false,
        "transparent": false,
        "center": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
